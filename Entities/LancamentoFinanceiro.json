{
  "name": "LancamentoFinanceiro",
  "type": "object",
  "properties": {
    "tipo": {
      "type": "string",
      "enum": [
        "Entrada",
        "Sa\u00edda"
      ]
    },
    "categoria": {
      "type": "string",
      "enum": [
        "Honor\u00e1rios",
        "Custas Processuais",
        "Despesas Operacionais",
        "Reembolso",
        "Sal\u00e1rios",
        "Aluguel",
        "Material",
        "Marketing",
        "Tecnologia",
        "Outro"
      ],
      "default": "Honor\u00e1rios"
    },
    "descricao": {
      "type": "string"
    },
    "valor": {
      "type": "number"
    },
    "data": {
      "type": "string",
      "format": "date"
    },
    "data_vencimento": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pendente",
        "Confirmado",
        "Cancelado"
      ],
      "default": "Confirmado"
    },
    "forma_pagamento": {
      "type": "string",
      "enum": [
        "Pix",
        "Transfer\u00eancia",
        "Dinheiro",
        "Cheque",
        "Cart\u00e3o de D\u00e9bito",
        "Cart\u00e3o de Cr\u00e9dito",
        "Boleto"
      ],
      "default": "Pix"
    },
    "cliente_id": {
      "type": "string"
    },
    "cliente_nome": {
      "type": "string"
    },
    "processo_id": {
      "type": "string"
    },
    "comprovante_url": {
      "type": "string"
    },
    "observacoes": {
      "type": "string"
    },
    "conciliado": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "tipo",
    "valor",
    "data",
    "descricao"
  ]
}
