{
  "name": "InstagramCanal",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "Conta Principal",
        "Mentoria",
        "Clube do Livro",
        "Canal WhatsApp",
        "Outro"
      ],
      "default": "Conta Principal"
    },
    "arroba": {
      "type": "string"
    },
    "frequencia_postagem": {
      "type": "string"
    },
    "responsavel": {
      "type": "string"
    },
    "conteudos_enviados": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "Ativo",
        "Pausado",
        "Planejado"
      ],
      "default": "Ativo"
    },
    "observacoes": {
      "type": "string"
    },
    "anexos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "nome"
  ]
}
