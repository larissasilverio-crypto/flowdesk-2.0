{
  "name": "HistoricoAgenda",
  "type": "object",
  "properties": {
    "evento_id": {
      "type": "string",
      "description": "ID do evento relacionado"
    },
    "usuario_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio que fez a altera\u00e7\u00e3o"
    },
    "tipo_acao": {
      "type": "string",
      "enum": [
        "Cria\u00e7\u00e3o",
        "Edi\u00e7\u00e3o",
        "Exclus\u00e3o",
        "Reagendamento",
        "Mudan\u00e7a de Status"
      ],
      "default": "Edi\u00e7\u00e3o"
    },
    "campo_alterado": {
      "type": "string",
      "description": "Nome do campo alterado"
    },
    "valor_anterior": {
      "type": "string",
      "description": "Valor antes da altera\u00e7\u00e3o"
    },
    "valor_novo": {
      "type": "string",
      "description": "Valor ap\u00f3s a altera\u00e7\u00e3o"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o da altera\u00e7\u00e3o"
    }
  },
  "required": [
    "evento_id",
    "tipo_acao"
  ]
}
