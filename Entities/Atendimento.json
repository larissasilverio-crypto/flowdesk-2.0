{
  "name": "Atendimento",
  "type": "object",
  "properties": {
    "numero_caso": {
      "type": "string",
      "description": "N\u00famero \u00fanico do caso"
    },
    "ordem_prioridade": {
      "type": "number",
      "description": "Ordem de prioridade do atendimento (1 = mais priorit\u00e1rio)"
    },
    "cliente": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "qualificacao": {
      "type": "string",
      "description": "Qualifica\u00e7\u00e3o do cliente (CPF, RG, etc)"
    },
    "assunto": {
      "type": "string",
      "description": "Assunto do atendimento"
    },
    "tipo_demanda": {
      "type": "string",
      "enum": [
        "Processo Judicial",
        "Pedido Administrativo",
        "Colher Documentos",
        "Acompanhamento",
        "Outro"
      ],
      "default": "Outro",
      "description": "Tipo de demanda"
    },
    "potencial": {
      "type": "string",
      "enum": [
        "Alto",
        "M\u00e9dio",
        "Baixo"
      ],
      "default": "M\u00e9dio",
      "description": "Potencial do caso"
    },
    "status": {
      "type": "string",
      "enum": [
        "Em aberto",
        "Conclu\u00eddo",
        "Convertido em tarefa"
      ],
      "default": "Em aberto"
    },
    "status_detalhado": {
      "type": "string",
      "enum": [
        "Em triagem",
        "Em an\u00e1lise da Dra.",
        "Criar tarefa",
        "Encerrado",
        "Sem direito/interesse"
      ],
      "default": "Em triagem"
    },
    "tipo_atendimento": {
      "type": "string",
      "enum": [
        "Presencial",
        "Online"
      ],
      "default": "Presencial"
    },
    "data_chegada": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora de chegada"
    },
    "data_atendimento": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora do atendimento"
    },
    "observacoes": {
      "type": "string"
    },
    "motivo_encerramento": {
      "type": "string",
      "description": "Motivo do encerramento se n\u00e3o houver prosseguimento"
    },
    "tarefa_criada_id": {
      "type": "string",
      "description": "ID da tarefa criada a partir deste atendimento"
    },
    "data_conversao_tarefa": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora da convers\u00e3o em tarefa"
    },
    "usuario_conversao_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio que fez a convers\u00e3o"
    },
    "controle_execucao_id": {
      "type": "string",
      "description": "ID do controle de execu\u00e7\u00e3o criado"
    },
    "andamento_administrativo_id": {
      "type": "string",
      "description": "ID do andamento administrativo criado"
    },
    "anexos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs dos documentos anexados"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do respons\u00e1vel pelo atendimento"
    }
  },
  "required": [
    "cliente",
    "status"
  ]
}
