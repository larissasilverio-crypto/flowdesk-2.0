{
  "name": "LeadComercial",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome do lead"
    },
    "contato": {
      "type": "string",
      "description": "Telefone ou email"
    },
    "origem": {
      "type": "string",
      "description": "De onde veio (nome da LP, rede social, etc)"
    },
    "landing_page_id": {
      "type": "string",
      "description": "ID da landing page de origem"
    },
    "interesse": {
      "type": "string",
      "enum": [
        "BPC",
        "Aposentadoria",
        "Revis\u00e3o",
        "INSS",
        "Fam\u00edlia",
        "Trabalhista",
        "Outro"
      ],
      "default": "BPC"
    },
    "status": {
      "type": "string",
      "enum": [
        "Novo",
        "Em Contato",
        "Qualificado",
        "Convertido",
        "Perdido",
        "Desqualificado"
      ],
      "default": "Novo"
    },
    "proxima_acao": {
      "type": "string",
      "description": "Pr\u00f3ximo passo"
    },
    "data_proxima_acao": {
      "type": "string",
      "format": "date"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do respons\u00e1vel"
    },
    "observacoes": {
      "type": "string"
    },
    "historico": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Hist\u00f3rico de intera\u00e7\u00f5es"
    },
    "valor_potencial": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "nome",
    "contato",
    "status"
  ]
}
