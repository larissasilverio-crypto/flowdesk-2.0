{
  "name": "ConclusaoAdmINSS",
  "type": "object",
  "properties": {
    "administrativo_inss_id": {
      "type": "string"
    },
    "data_conclusao": {
      "type": "string",
      "format": "date"
    },
    "tipo_conclusao": {
      "type": "string",
      "enum": [
        "Deferido finalizado",
        "Indeferido encerrado",
        "Desist\u00eancia",
        "Perda de objeto",
        "Encerrado sem judicializa\u00e7\u00e3o",
        "Migrado para judicial",
        "Outro"
      ]
    },
    "resultado_final": {
      "type": "string"
    },
    "observacoes_finais": {
      "type": "string"
    }
  },
  "required": [
    "administrativo_inss_id",
    "tipo_conclusao"
  ]
}
