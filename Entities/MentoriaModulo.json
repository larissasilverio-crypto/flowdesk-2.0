{
  "name": "MentoriaModulo",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome do m\u00f3dulo"
    },
    "descricao": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Ativo",
        "Em prepara\u00e7\u00e3o",
        "Conclu\u00eddo",
        "Pausado"
      ],
      "default": "Ativo"
    },
    "data": {
      "type": "string",
      "format": "date"
    },
    "link_externo": {
      "type": "string"
    },
    "observacoes": {
      "type": "string"
    },
    "anexos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ordem": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "nome"
  ]
}
