{
  "name": "MonitoramentoProcessual",
  "type": "object",
  "properties": {
    "numero_processo": {
      "type": "string",
      "description": "N\u00famero do processo judicial"
    },
    "cliente_parte": {
      "type": "string",
      "description": "Nome do cliente ou parte"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID da pessoa respons\u00e1vel pelo monitoramento"
    },
    "tribunal_orgao_atual": {
      "type": "string",
      "enum": [
        "1\u00ba Grau",
        "2\u00ba Grau (TJ/TRF)",
        "STJ",
        "STF"
      ],
      "description": "Tribunal ou \u00f3rg\u00e3o onde o processo est\u00e1 atualmente"
    },
    "tipo_controle": {
      "type": "string",
      "enum": [
        "Apenas acompanhamento",
        "Aguardando decis\u00e3o",
        "Em fase de recurso",
        "Recurso interposto",
        "Aguardando julgamento",
        "Decis\u00e3o publicada (analisar)"
      ],
      "description": "Tipo de controle/fase do processo"
    },
    "o_que_precisa_ser_feito": {
      "type": "string",
      "description": "A\u00e7\u00e3o ou verifica\u00e7\u00e3o necess\u00e1ria"
    },
    "proxima_checagem": {
      "type": "string",
      "format": "date",
      "description": "Data da pr\u00f3xima verifica\u00e7\u00e3o"
    },
    "status": {
      "type": "string",
      "enum": [
        "Em Monitoramento",
        "Conclu\u00eddo"
      ],
      "default": "Em Monitoramento",
      "description": "Status do monitoramento"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es adicionais"
    }
  },
  "required": [
    "numero_processo",
    "cliente_parte",
    "responsavel_id",
    "tribunal_orgao_atual",
    "tipo_controle",
    "o_que_precisa_ser_feito",
    "proxima_checagem",
    "status"
  ]
}
