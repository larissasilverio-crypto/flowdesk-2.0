{
  "name": "DocumentoVinculado",
  "type": "object",
  "properties": {
    "nome_documento": {
      "type": "string",
      "description": "Nome edit\u00e1vel do documento"
    },
    "nome_original_arquivo": {
      "type": "string",
      "description": "Nome original do arquivo enviado"
    },
    "arquivo_url": {
      "type": "string",
      "description": "URL do arquivo enviado"
    },
    "tipo_documento": {
      "type": "string",
      "enum": [
        "Documento pessoal",
        "Procura\u00e7\u00e3o",
        "Comprovante",
        "CNIS",
        "Laudo",
        "Requerimento",
        "Peti\u00e7\u00e3o",
        "Senten\u00e7a",
        "Decis\u00e3o",
        "Guia",
        "Comprovante de resid\u00eancia",
        "Outro"
      ],
      "default": "Outro"
    },
    "categoria_documento": {
      "type": "string",
      "enum": [
        "Pessoal",
        "M\u00e9dico",
        "Administrativo",
        "Jur\u00eddico",
        "Outro"
      ],
      "default": "Outro"
    },
    "cliente_id": {
      "type": "string",
      "description": "ID do cliente vinculado (opcional)"
    },
    "processo_id": {
      "type": "string",
      "description": "ID do processo vinculado (opcional)"
    },
    "descricao_documento": {
      "type": "string"
    },
    "data_documento": {
      "type": "string",
      "format": "date"
    },
    "observacoes": {
      "type": "string"
    },
    "criado_por": {
      "type": "string"
    },
    "atualizado_por": {
      "type": "string"
    }
  },
  "required": [
    "nome_documento",
    "arquivo_url"
  ]
}
