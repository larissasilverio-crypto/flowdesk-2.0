{
  "name": "CopiasPA",
  "type": "object",
  "properties": {
    "adm_id": {
      "type": "string",
      "description": "ID do Administrativo INSS"
    },
    "cliente_nome": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "C\u00f3pia de PA",
        "Processo Administrativo",
        "Recurso",
        "Exig\u00eancia",
        "Despacho",
        "Parecer",
        "Outro"
      ],
      "default": "C\u00f3pia de PA"
    },
    "numero_pa": {
      "type": "string",
      "description": "N\u00famero do processo administrativo"
    },
    "data": {
      "type": "string",
      "format": "date"
    },
    "responsavel": {
      "type": "string",
      "description": "Respons\u00e1vel pelo acompanhamento"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pendente",
        "Em andamento",
        "Conclu\u00eddo",
        "Arquivado"
      ],
      "default": "Pendente"
    },
    "descricao": {
      "type": "string"
    },
    "observacoes": {
      "type": "string"
    },
    "anexos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs dos arquivos anexados"
    }
  },
  "required": [
    "cliente_nome",
    "tipo"
  ]
}
