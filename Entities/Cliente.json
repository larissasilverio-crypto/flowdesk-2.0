{
  "name": "Cliente",
  "type": "object",
  "properties": {
    "nome_completo": {
      "type": "string",
      "description": "Nome completo do cliente"
    },
    "cpf": {
      "type": "string",
      "description": "CPF do cliente (\u00fanico)"
    },
    "rg": {
      "type": "string",
      "description": "RG do cliente"
    },
    "data_nascimento": {
      "type": "string",
      "format": "date",
      "description": "Data de nascimento"
    },
    "telefone": {
      "type": "string",
      "description": "Telefone de contato"
    },
    "email": {
      "type": "string",
      "description": "E-mail do cliente"
    },
    "endereco_completo": {
      "type": "string",
      "description": "Endere\u00e7o completo"
    },
    "cidade": {
      "type": "string",
      "description": "Cidade"
    },
    "estado": {
      "type": "string",
      "description": "Estado (UF)"
    },
    "cep": {
      "type": "string",
      "description": "CEP"
    },
    "profissao": {
      "type": "string",
      "description": "Profiss\u00e3o do cliente"
    },
    "renda_mensal": {
      "type": "number",
      "description": "Renda mensal em reais"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es gerais"
    },
    "criado_por": {
      "type": "string",
      "description": "E-mail do usu\u00e1rio que criou o registro"
    },
    "atualizado_por": {
      "type": "string",
      "description": "E-mail do usu\u00e1rio que atualizou por \u00faltimo"
    },
    "id_externo": {
      "type": "string",
      "description": "ID do sistema antigo para migra\u00e7\u00e3o e rastreabilidade"
    }
  },
  "required": [
    "nome_completo",
    "cpf",
    "telefone"
  ]
}
