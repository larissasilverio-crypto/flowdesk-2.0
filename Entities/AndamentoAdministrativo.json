{
  "name": "AndamentoAdministrativo",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo do andamento"
    },
    "atendimento_id": {
      "type": "string",
      "description": "ID do atendimento de origem"
    },
    "cliente": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "orgao": {
      "type": "string",
      "description": "\u00d3rg\u00e3o administrativo (ex: INSS)"
    },
    "tipo_pedido": {
      "type": "string",
      "description": "Tipo de pedido ou exig\u00eancia"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do andamento"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es e anota\u00e7\u00f5es"
    },
    "anexos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs dos documentos anexados"
    },
    "status": {
      "type": "string",
      "enum": [
        "Em aberto",
        "Conclu\u00eddo"
      ],
      "default": "Em aberto"
    },
    "status_detalhado": {
      "type": "string",
      "enum": [
        "Aguardando",
        "Em an\u00e1lise",
        "Respondido",
        "Conclu\u00eddo"
      ],
      "default": "Aguardando"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do respons\u00e1vel"
    }
  },
  "required": [
    "titulo",
    "status"
  ]
}
