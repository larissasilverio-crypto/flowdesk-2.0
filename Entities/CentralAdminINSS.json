{
  "name": "CentralAdminINSS",
  "type": "object",
  "properties": {
    "processo_id": {
      "type": "string",
      "description": "ID do processo vinculado (obrigat\u00f3rio)"
    },
    "cliente_id": {
      "type": "string",
      "description": "ID do cliente (autom\u00e1tico via processo)"
    },
    "numero_beneficio": {
      "type": "string"
    },
    "especie_beneficio": {
      "type": "string"
    },
    "tipo_requerimento": {
      "type": "string"
    },
    "status_administrativo_geral": {
      "type": "string",
      "enum": [
        "N\u00e3o iniciado",
        "Em prepara\u00e7\u00e3o",
        "Protocolado",
        "Aguardando agendamento",
        "Aguardando an\u00e1lise",
        "Exig\u00eancia pendente",
        "Deferido",
        "Indeferido",
        "Conclu\u00eddo"
      ],
      "default": "N\u00e3o iniciado"
    },
    "data_protocolo_principal": {
      "type": "string",
      "format": "date"
    },
    "numero_protocolo_principal": {
      "type": "string"
    },
    "unidade_responsavel": {
      "type": "string"
    },
    "servidor_responsavel": {
      "type": "string"
    },
    "prioridade": {
      "type": "string",
      "enum": [
        "Baixa",
        "M\u00e9dia",
        "Alta",
        "Urgente"
      ],
      "default": "M\u00e9dia"
    },
    "observacoes_gerais": {
      "type": "string"
    },
    "resumo_do_caso": {
      "type": "string"
    },
    "criado_por": {
      "type": "string"
    },
    "atualizado_por": {
      "type": "string"
    }
  },
  "required": [
    "processo_id"
  ]
}
