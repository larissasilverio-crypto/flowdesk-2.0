{
  "name": "SocialSelling",
  "type": "object",
  "properties": {
    "nome_contato": {
      "type": "string"
    },
    "instagram": {
      "type": "string"
    },
    "nivel_relacionamento": {
      "type": "string",
      "enum": [
        "Frio",
        "Morno",
        "Quente"
      ],
      "default": "Frio"
    },
    "ultima_interacao": {
      "type": "string",
      "format": "date"
    },
    "tipo_interacao": {
      "type": "string",
      "enum": [
        "Respondeu story",
        "Comentou",
        "DM",
        "Curtiu",
        "Seguiu",
        "Outro"
      ],
      "default": "Outro"
    },
    "proximo_passo": {
      "type": "string"
    },
    "observacoes": {
      "type": "string"
    },
    "anexos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "nome_contato"
  ]
}
