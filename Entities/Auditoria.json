{
  "name": "Auditoria",
  "type": "object",
  "properties": {
    "usuario_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio que executou a a\u00e7\u00e3o"
    },
    "modulo": {
      "type": "string",
      "enum": [
        "Atendimento",
        "Tarefa",
        "Agenda",
        "Processo Administrativo",
        "Processo Judicial",
        "Execu\u00e7\u00e3o",
        "Aguardando Documentos",
        "Retorno Cliente",
        "Sistema"
      ],
      "description": "M\u00f3dulo onde a a\u00e7\u00e3o ocorreu"
    },
    "tipo_acao": {
      "type": "string",
      "enum": [
        "Cria\u00e7\u00e3o",
        "Edi\u00e7\u00e3o",
        "Exclus\u00e3o",
        "Conclus\u00e3o",
        "Reabertura",
        "Delega\u00e7\u00e3o",
        "Transfer\u00eancia",
        "Mudan\u00e7a de Status",
        "Anexo Adicionado",
        "Anexo Removido"
      ],
      "description": "Tipo da a\u00e7\u00e3o executada"
    },
    "registro_id": {
      "type": "string",
      "description": "ID do registro afetado"
    },
    "registro_nome": {
      "type": "string",
      "description": "Nome/t\u00edtulo do registro afetado"
    },
    "campo_alterado": {
      "type": "string",
      "description": "Nome do campo alterado"
    },
    "valor_anterior": {
      "type": "string",
      "description": "Valor antes da altera\u00e7\u00e3o"
    },
    "valor_novo": {
      "type": "string",
      "description": "Valor ap\u00f3s a altera\u00e7\u00e3o"
    },
    "observacao_sistema": {
      "type": "string",
      "description": "Observa\u00e7\u00e3o autom\u00e1tica gerada pelo sistema"
    },
    "ip_origem": {
      "type": "string",
      "description": "IP de origem da a\u00e7\u00e3o"
    }
  },
  "required": [
    "modulo",
    "tipo_acao"
  ]
}
