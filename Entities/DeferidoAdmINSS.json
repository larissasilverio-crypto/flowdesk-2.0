{
  "name": "DeferidoAdmINSS",
  "type": "object",
  "properties": {
    "administrativo_inss_id": {
      "type": "string"
    },
    "data_deferimento": {
      "type": "string",
      "format": "date"
    },
    "tipo_beneficio_deferido": {
      "type": "string"
    },
    "numero_beneficio": {
      "type": "string"
    },
    "valor_concedido": {
      "type": "number"
    },
    "renda_mensal_inicial": {
      "type": "number"
    },
    "data_inicio_beneficio": {
      "type": "string",
      "format": "date"
    },
    "status_pos_deferimento": {
      "type": "string",
      "enum": [
        "Implantado",
        "Ativo",
        "Pendente de confer\u00eancia",
        "Encerrado"
      ],
      "default": "Ativo"
    },
    "observacoes": {
      "type": "string"
    }
  },
  "required": [
    "administrativo_inss_id"
  ]
}
