{
  "name": "ConfiguracaoAgenda",
  "type": "object",
  "properties": {
    "nome_tarja": {
      "type": "string",
      "description": "Nome da tarja/categoria personalizada"
    },
    "cor": {
      "type": "string",
      "description": "C\u00f3digo da cor em formato Tailwind (ex: bg-red-500)"
    },
    "palavras_chave": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Palavras-chave que ativam esta cor automaticamente"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o da categoria"
    },
    "ativa": {
      "type": "boolean",
      "default": true,
      "description": "Se esta configura\u00e7\u00e3o est\u00e1 ativa"
    }
  },
  "required": [
    "nome_tarja",
    "cor"
  ]
}
