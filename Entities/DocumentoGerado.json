{
  "name": "DocumentoGerado",
  "type": "object",
  "properties": {
    "modelo_id": {
      "type": "string",
      "description": "ID do modelo de origem"
    },
    "nome_modelo": {
      "type": "string",
      "description": "Nome do modelo usado"
    },
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo do documento gerado"
    },
    "cliente_id": {
      "type": "string",
      "description": "ID do cliente vinculado"
    },
    "cliente_nome": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "processo_id": {
      "type": "string",
      "description": "ID do processo vinculado"
    },
    "arquivo_url": {
      "type": "string",
      "description": "URL do documento final gerado"
    },
    "nome_arquivo": {
      "type": "string",
      "description": "Nome do arquivo gerado"
    },
    "dados_preenchidos": {
      "type": "string",
      "description": "JSON com os dados preenchidos (campos vari\u00e1veis)"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es adicionais"
    },
    "status": {
      "type": "string",
      "enum": [
        "rascunho",
        "finalizado",
        "enviado"
      ],
      "default": "finalizado"
    },
    "gerado_por": {
      "type": "string",
      "description": "Email do usu\u00e1rio que gerou"
    }
  },
  "required": [
    "modelo_id",
    "titulo"
  ]
}
