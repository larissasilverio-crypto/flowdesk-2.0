{
  "name": "ConclusaoINSS",
  "type": "object",
  "properties": {
    "processo_id": {
      "type": "string"
    },
    "central_id": {
      "type": "string"
    },
    "tipo_encerramento": {
      "type": "string",
      "enum": [
        "Deferido finalizado",
        "Indeferido encerrado",
        "Desist\u00eancia",
        "Perda de objeto",
        "Migrado para judicial",
        "Outro"
      ]
    },
    "data_conclusao": {
      "type": "string",
      "format": "date"
    },
    "motivo_conclusao": {
      "type": "string"
    },
    "resultado_final": {
      "type": "string"
    },
    "houve_desdobramento_judicial": {
      "type": "string",
      "enum": [
        "Sim",
        "N\u00e3o"
      ]
    },
    "observacoes_finais": {
      "type": "string"
    },
    "criado_por": {
      "type": "string"
    },
    "atualizado_por": {
      "type": "string"
    }
  },
  "required": [
    "processo_id",
    "tipo_encerramento"
  ]
}
