{
  "name": "ConfiguracaoIA",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome da configura\u00e7\u00e3o"
    },
    "instrucoes": {
      "type": "string",
      "description": "Instru\u00e7\u00f5es gerais da IA"
    },
    "base_conhecimento": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs dos documentos de treinamento"
    },
    "linguagem_permitida": {
      "type": "string",
      "description": "Diretrizes de linguagem"
    },
    "restricoes": {
      "type": "string",
      "description": "O que a IA n\u00e3o pode fazer ou falar"
    },
    "padrao_resposta": {
      "type": "string",
      "description": "Modelo padr\u00e3o de resposta"
    },
    "versao": {
      "type": "string",
      "default": "1.0",
      "description": "Vers\u00e3o do treinamento"
    },
    "ativa": {
      "type": "boolean",
      "default": true,
      "description": "Se esta configura\u00e7\u00e3o est\u00e1 ativa"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "Atendimento",
        "Capta\u00e7\u00e3o",
        "Conte\u00fado",
        "Geral"
      ],
      "default": "Geral"
    }
  },
  "required": [
    "nome",
    "instrucoes"
  ]
}
