{
  "name": "ProcessoAdministrativoINSS",
  "type": "object",
  "properties": {
    "cliente": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "atendimento_id": {
      "type": "string",
      "description": "ID do atendimento relacionado"
    },
    "numero_protocolo": {
      "type": "string",
      "description": "N\u00famero do protocolo INSS"
    },
    "tipo_beneficio": {
      "type": "string",
      "description": "Tipo de benef\u00edcio requerido (BPC, Aposentadoria, etc)"
    },
    "data_requerimento": {
      "type": "string",
      "format": "date",
      "description": "Data do requerimento"
    },
    "status": {
      "type": "string",
      "enum": [
        "Em an\u00e1lise",
        "Aguardando documentos",
        "Deferido",
        "Indeferido",
        "Recurso",
        "Conclu\u00eddo"
      ],
      "default": "Em an\u00e1lise",
      "description": "Status do processo"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es internas"
    },
    "login_meu_inss": {
      "type": "string",
      "description": "Login do Meu INSS"
    },
    "cpf": {
      "type": "string",
      "description": "CPF do benefici\u00e1rio"
    },
    "senha_gov": {
      "type": "string",
      "description": "Senha Gov.br (armazenada com cuidado)"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do respons\u00e1vel"
    },
    "concluido_por": {
      "type": "string",
      "description": "Nome ou ID de quem concluiu"
    },
    "data_conclusao": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora da conclus\u00e3o"
    }
  },
  "required": [
    "cliente",
    "status"
  ]
}
