{
  "name": "Processo",
  "type": "object",
  "properties": {
    "numero_processo": {
      "type": "string",
      "description": "N\u00famero do processo (\u00fanico)"
    },
    "cliente_id": {
      "type": "string",
      "description": "ID do cliente vinculado (obrigat\u00f3rio)"
    },
    "tipo_processo": {
      "type": "string",
      "enum": [
        "Previdenci\u00e1rio",
        "Trabalhista",
        "Banc\u00e1rio",
        "C\u00edvel",
        "Criminal",
        "Tribut\u00e1rio",
        "Administrativo",
        "Outro"
      ],
      "description": "Tipo do processo"
    },
    "status": {
      "type": "string",
      "enum": [
        "Em andamento",
        "Conclu\u00eddo",
        "Suspenso",
        "Arquivado",
        "Aguardando"
      ],
      "default": "Em andamento",
      "description": "Status atual do processo"
    },
    "data_inicio": {
      "type": "string",
      "format": "date",
      "description": "Data de in\u00edcio do processo"
    },
    "data_fim": {
      "type": "string",
      "format": "date",
      "description": "Data de encerramento (opcional)"
    },
    "orgao": {
      "type": "string",
      "description": "\u00d3rg\u00e3o respons\u00e1vel (ex: INSS, Justi\u00e7a Federal)"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada do processo"
    },
    "valor_causa": {
      "type": "number",
      "description": "Valor da causa em reais"
    },
    "fase_processo": {
      "type": "string",
      "enum": [
        "Inicial",
        "Instru\u00e7\u00e3o",
        "Senten\u00e7a",
        "Recurso",
        "Execu\u00e7\u00e3o",
        "Tr\u00e2nsito em julgado",
        "Encerrado"
      ],
      "description": "Fase atual do processo"
    },
    "criado_por": {
      "type": "string",
      "description": "E-mail do usu\u00e1rio que criou o registro"
    },
    "atualizado_por": {
      "type": "string",
      "description": "E-mail do usu\u00e1rio que atualizou por \u00faltimo"
    },
    "id_externo": {
      "type": "string",
      "description": "ID do sistema antigo para migra\u00e7\u00e3o e rastreabilidade"
    }
  },
  "required": [
    "numero_processo",
    "cliente_id",
    "tipo_processo",
    "status",
    "data_inicio"
  ]
}
