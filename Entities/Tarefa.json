{
  "name": "Tarefa",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo da tarefa"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada"
    },
    "origem": {
      "type": "string",
      "enum": [
        "Manual",
        "Atendimento",
        "Sistema"
      ],
      "default": "Manual",
      "description": "Origem da cria\u00e7\u00e3o da tarefa"
    },
    "atendimento_id": {
      "type": "string",
      "description": "ID do atendimento relacionado"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID da pessoa respons\u00e1vel"
    },
    "data_inicio": {
      "type": "string",
      "format": "date"
    },
    "data_vencimento": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "Em aberto",
        "Conclu\u00edda",
        "N\u00e3o realizada / Impedimento"
      ],
      "default": "Em aberto"
    },
    "status_detalhado": {
      "type": "string",
      "enum": [
        "Pendente",
        "Em andamento",
        "Atrasada",
        "Conclu\u00edda"
      ],
      "default": "Pendente"
    },
    "estado_execucao": {
      "type": "string",
      "enum": [
        "Em dia",
        "Vence hoje",
        "Atrasado"
      ],
      "description": "Calculado automaticamente baseado na data de vencimento"
    },
    "prioridade": {
      "type": "string",
      "enum": [
        "Baixa",
        "M\u00e9dia",
        "Alta"
      ],
      "default": "M\u00e9dia"
    },
    "anexos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs dos documentos e imagens anexados"
    },
    "observacoes": {
      "type": "string"
    },
    "retorno_executivo": {
      "type": "string",
      "description": "Retorno executivo - obrigat\u00f3rio para conclus\u00e3o da tarefa"
    },
    "transferido_para": {
      "type": "string",
      "description": "ID do usu\u00e1rio para quem a tarefa foi transferida"
    },
    "mencoes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs dos usu\u00e1rios mencionados"
    }
  },
  "required": [
    "titulo",
    "responsavel_id",
    "data_vencimento",
    "status"
  ]
}
