{
  "name": "ControleProcessoExecucao",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo do acompanhamento"
    },
    "atendimento_id": {
      "type": "string",
      "description": "ID do atendimento de origem"
    },
    "cliente": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do acompanhamento"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es e anota\u00e7\u00f5es"
    },
    "tipo_movimentacao": {
      "type": "string",
      "description": "Tipo de movimenta\u00e7\u00e3o processual"
    },
    "anexos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs dos documentos anexados"
    },
    "status": {
      "type": "string",
      "enum": [
        "Em aberto",
        "Conclu\u00eddo",
        "Gerar tarefa",
        "Tarefa gerada"
      ],
      "default": "Em aberto"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do respons\u00e1vel"
    },
    "tarefa_criada_id": {
      "type": "string",
      "description": "ID da tarefa criada a partir deste controle"
    },
    "data_conversao_tarefa": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora da convers\u00e3o em tarefa"
    },
    "usuario_conversao_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio que fez a convers\u00e3o"
    }
  },
  "required": [
    "titulo",
    "status"
  ]
}
