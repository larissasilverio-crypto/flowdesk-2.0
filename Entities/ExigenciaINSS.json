{
  "name": "ExigenciaINSS",
  "type": "object",
  "properties": {
    "processo_id": {
      "type": "string"
    },
    "central_id": {
      "type": "string"
    },
    "protocolo_relacionado": {
      "type": "string"
    },
    "data_emissao_exigencia": {
      "type": "string",
      "format": "date"
    },
    "prazo_final": {
      "type": "string",
      "format": "date"
    },
    "descricao_exigencia": {
      "type": "string"
    },
    "documentos_solicitados": {
      "type": "string"
    },
    "responsavel_interno": {
      "type": "string"
    },
    "status_exigencia": {
      "type": "string",
      "enum": [
        "Pendente",
        "Em andamento",
        "Aguardando cliente",
        "Cumprida",
        "Enviada",
        "Vencida",
        "Cancelada"
      ],
      "default": "Pendente"
    },
    "data_cumprimento": {
      "type": "string",
      "format": "date"
    },
    "forma_cumprimento": {
      "type": "string"
    },
    "comprovante_envio": {
      "type": "string"
    },
    "observacoes": {
      "type": "string"
    },
    "criado_por": {
      "type": "string"
    },
    "atualizado_por": {
      "type": "string"
    }
  },
  "required": [
    "processo_id",
    "descricao_exigencia"
  ]
}
