{
  "name": "SnapshotProdutividade",
  "type": "object",
  "properties": {
    "usuario_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio"
    },
    "data_snapshot": {
      "type": "string",
      "format": "date",
      "description": "Data do snapshot"
    },
    "atendimentos_criados": {
      "type": "number",
      "default": 0
    },
    "atendimentos_concluidos": {
      "type": "number",
      "default": 0
    },
    "tarefas_criadas": {
      "type": "number",
      "default": 0
    },
    "tarefas_concluidas": {
      "type": "number",
      "default": 0
    },
    "eventos_agendados": {
      "type": "number",
      "default": 0
    },
    "eventos_realizados": {
      "type": "number",
      "default": 0
    },
    "processos_criados": {
      "type": "number",
      "default": 0
    },
    "processos_concluidos": {
      "type": "number",
      "default": 0
    },
    "taxa_conclusao": {
      "type": "number",
      "default": 0,
      "description": "Taxa de conclus\u00e3o em percentual"
    },
    "total_acoes": {
      "type": "number",
      "default": 0
    },
    "total_concluidos": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "usuario_id",
    "data_snapshot"
  ]
}
