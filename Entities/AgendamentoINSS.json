{
  "name": "AgendamentoINSS",
  "type": "object",
  "properties": {
    "cliente": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "atendimento_id": {
      "type": "string",
      "description": "ID do atendimento relacionado"
    },
    "numero_protocolo": {
      "type": "string",
      "description": "N\u00famero do protocolo INSS"
    },
    "data_protocolo": {
      "type": "string",
      "format": "date",
      "description": "Data do protocolo"
    },
    "data_pericia": {
      "type": "string",
      "format": "date",
      "description": "Data da per\u00edcia m\u00e9dica"
    },
    "data_avaliacao_social": {
      "type": "string",
      "format": "date",
      "description": "Data da avalia\u00e7\u00e3o social"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es adicionais"
    },
    "status": {
      "type": "string",
      "enum": [
        "Agendado",
        "Conclu\u00eddo",
        "Cancelado"
      ],
      "default": "Agendado",
      "description": "Status do agendamento"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do respons\u00e1vel"
    }
  },
  "required": [
    "cliente",
    "status"
  ]
}
