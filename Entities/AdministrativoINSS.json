{
  "name": "AdministrativoINSS",
  "type": "object",
  "properties": {
    "cliente_id": {
      "type": "string",
      "description": "ID do cliente vinculado (obrigat\u00f3rio)"
    },
    "titulo_administrativo": {
      "type": "string"
    },
    "tipo_administrativo": {
      "type": "string",
      "enum": [
        "Aposentadoria",
        "Benef\u00edcio por incapacidade",
        "BPC/LOAS",
        "Pens\u00e3o por morte",
        "Sal\u00e1rio-maternidade",
        "Aux\u00edlio Doen\u00e7a",
        "Aux\u00edlio Acidente",
        "Revis\u00e3o",
        "Recurso administrativo",
        "Exig\u00eancia administrativa",
        "Emiss\u00e3o de guias",
        "Outro"
      ]
    },
    "numero_beneficio": {
      "type": "string"
    },
    "numero_protocolo_principal": {
      "type": "string"
    },
    "status_geral": {
      "type": "string",
      "enum": [
        "N\u00e3o iniciado",
        "Em prepara\u00e7\u00e3o",
        "Protocolado",
        "Aguardando agendamento",
        "Aguardando per\u00edcia",
        "Aguardando avalia\u00e7\u00e3o social",
        "Exig\u00eancia pendente",
        "Deferido",
        "Indeferido",
        "Conclu\u00eddo",
        "Encerrado"
      ],
      "default": "N\u00e3o iniciado"
    },
    "orgao_responsavel": {
      "type": "string",
      "default": "INSS"
    },
    "unidade_responsavel": {
      "type": "string"
    },
    "prioridade": {
      "type": "string",
      "enum": [
        "Baixa",
        "M\u00e9dia",
        "Alta",
        "Urgente"
      ],
      "default": "M\u00e9dia"
    },
    "data_inicio": {
      "type": "string",
      "format": "date"
    },
    "data_fim": {
      "type": "string",
      "format": "date"
    },
    "resumo_do_caso": {
      "type": "string"
    },
    "observacoes_gerais": {
      "type": "string"
    },
    "criado_por": {
      "type": "string"
    },
    "atualizado_por": {
      "type": "string"
    }
  },
  "required": [
    "cliente_id",
    "tipo_administrativo"
  ]
}
