{
  "name": "Feedback12Semanas",
  "type": "object",
  "properties": {
    "ciclo_id": {
      "type": "string",
      "description": "ID do ciclo"
    },
    "tipo_feedback": {
      "type": "string",
      "enum": [
        "Individual",
        "Coletivo"
      ],
      "default": "Individual",
      "description": "Tipo de feedback"
    },
    "usuario_avaliado_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio avaliado (se individual)"
    },
    "setor_avaliado": {
      "type": "string",
      "description": "Setor avaliado (se coletivo)"
    },
    "indicadores_relacionados": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs dos indicadores relacionados ao feedback"
    },
    "observacoes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es do feedback"
    },
    "pontuacao": {
      "type": "number",
      "description": "Pontua\u00e7\u00e3o de 0 a 10"
    },
    "avaliador_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio que fez a avalia\u00e7\u00e3o"
    }
  },
  "required": [
    "ciclo_id",
    "tipo_feedback"
  ]
}
