{
  "name": "AcaoCorretiva12Semanas",
  "type": "object",
  "properties": {
    "indicador_id": {
      "type": "string",
      "description": "ID do indicador relacionado"
    },
    "ciclo_id": {
      "type": "string",
      "description": "ID do ciclo"
    },
    "acao_definida": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o da a\u00e7\u00e3o corretiva"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do respons\u00e1vel pela a\u00e7\u00e3o"
    },
    "prazo": {
      "type": "string",
      "format": "date",
      "description": "Prazo para execu\u00e7\u00e3o"
    },
    "status_acao": {
      "type": "string",
      "enum": [
        "Pendente",
        "Em andamento",
        "Conclu\u00edda",
        "Cancelada"
      ],
      "default": "Pendente",
      "description": "Status da a\u00e7\u00e3o corretiva"
    },
    "tarefa_vinculada_id": {
      "type": "string",
      "description": "ID da tarefa criada automaticamente"
    },
    "resultado_obtido": {
      "type": "string",
      "description": "Resultado ap\u00f3s execu\u00e7\u00e3o da a\u00e7\u00e3o"
    }
  },
  "required": [
    "indicador_id",
    "ciclo_id",
    "acao_definida",
    "responsavel_id"
  ]
}
