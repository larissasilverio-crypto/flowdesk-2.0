{
  "name": "AguardandoDocumento",
  "type": "object",
  "properties": {
    "cliente": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "atendimento_id": {
      "type": "string",
      "description": "ID do atendimento relacionado"
    },
    "documentos_pendentes": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o dos documentos pendentes"
    },
    "data_solicitacao": {
      "type": "string",
      "format": "date",
      "description": "Data em que os documentos foram solicitados"
    },
    "prazo_entrega": {
      "type": "string",
      "format": "date",
      "description": "Prazo para entrega dos documentos"
    },
    "status": {
      "type": "string",
      "enum": [
        "Aguardando",
        "Recebido Parcialmente",
        "Recebido",
        "Cancelado"
      ],
      "default": "Aguardando"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID da pessoa respons\u00e1vel pelo acompanhamento"
    },
    "observacoes": {
      "type": "string"
    }
  },
  "required": [
    "cliente",
    "documentos_pendentes",
    "status"
  ]
}
