{
  "name": "LandingPage",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome da Landing Page"
    },
    "objetivo": {
      "type": "string",
      "enum": [
        "BPC",
        "Aposentadoria",
        "Revis\u00e3o",
        "INSS",
        "Fam\u00edlia",
        "Trabalhista",
        "Outro"
      ],
      "default": "BPC"
    },
    "url": {
      "type": "string",
      "description": "Link da LP"
    },
    "leads_gerados": {
      "type": "number",
      "default": 0,
      "description": "Quantidade de leads gerados"
    },
    "taxa_conversao": {
      "type": "number",
      "default": 0,
      "description": "Taxa de convers\u00e3o em %"
    },
    "observacoes": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Ativa",
        "Pausada",
        "Em Teste",
        "Desativada"
      ],
      "default": "Ativa"
    },
    "data_criacao": {
      "type": "string",
      "format": "date"
    },
    "responsavel_id": {
      "type": "string",
      "description": "ID do respons\u00e1vel"
    }
  },
  "required": [
    "nome",
    "objetivo"
  ]
}
