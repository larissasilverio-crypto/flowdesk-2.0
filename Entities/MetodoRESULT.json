{
  "name": "MetodoRESULT",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo do documento/material"
    },
    "descricao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do conte\u00fado"
    },
    "modulo": {
      "type": "string",
      "enum": [
        "Fundamentos",
        "Scripts de Atendimento",
        "Funil Comercial",
        "Padroniza\u00e7\u00e3o de Abordagem",
        "Indicadores de Performance",
        "Outro"
      ],
      "default": "Fundamentos"
    },
    "etapa": {
      "type": "string",
      "description": "Etapa do m\u00e9todo"
    },
    "tema": {
      "type": "string",
      "description": "Tema espec\u00edfico"
    },
    "arquivos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs dos arquivos (PDF, Word, PPT, Excel)"
    },
    "anotacoes": {
      "type": "string",
      "description": "Anota\u00e7\u00f5es estrat\u00e9gicas"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "titulo",
    "modulo"
  ]
}
