{
  "name": "BlocosDeNotasUsuario",
  "type": "object",
  "properties": {
    "usuario_id": {
      "type": "string",
      "description": "ID/email do usu\u00e1rio dono da anota\u00e7\u00e3o"
    },
    "titulo_bloco": {
      "type": "string",
      "description": "T\u00edtulo do bloco de notas"
    },
    "conteudo_bloco": {
      "type": "string",
      "description": "Conte\u00fado da anota\u00e7\u00e3o (texto longo)"
    },
    "categoria_bloco": {
      "type": "string",
      "enum": [
        "pessoal",
        "atendimento",
        "estrat\u00e9gia",
        "reuni\u00e3o",
        "rascunho",
        "outro"
      ],
      "default": "pessoal"
    },
    "status_bloco": {
      "type": "string",
      "enum": [
        "rascunho",
        "ativo",
        "arquivado"
      ],
      "default": "ativo"
    },
    "nome_arquivo_word": {
      "type": "string",
      "description": "Nome do arquivo Word gerado"
    },
    "arquivo_word_gerado": {
      "type": "string",
      "description": "URL do arquivo Word gerado"
    },
    "criado_por": {
      "type": "string"
    },
    "atualizado_por": {
      "type": "string"
    }
  },
  "required": [
    "usuario_id",
    "titulo_bloco"
  ]
}
