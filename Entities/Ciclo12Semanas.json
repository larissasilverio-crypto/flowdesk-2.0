{
  "name": "Ciclo12Semanas",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome do ciclo (ex: 12 Semanas \u2013 Jan/Mar 2026)"
    },
    "data_inicio": {
      "type": "string",
      "format": "date",
      "description": "Data de in\u00edcio do ciclo"
    },
    "data_termino": {
      "type": "string",
      "format": "date",
      "description": "Data de t\u00e9rmino do ciclo"
    },
    "status": {
      "type": "string",
      "enum": [
        "Planejamento",
        "Em execu\u00e7\u00e3o",
        "Em revis\u00e3o",
        "Conclu\u00eddo"
      ],
      "default": "Planejamento",
      "description": "Status do ciclo"
    },
    "setor_foco": {
      "type": "string",
      "description": "Setor principal de foco do ciclo"
    },
    "objetivos_gerais": {
      "type": "string",
      "description": "Objetivos gerais do ciclo"
    },
    "resultado_geral": {
      "type": "number",
      "default": 0,
      "description": "Percentual de resultado geral do ciclo"
    }
  },
  "required": [
    "nome",
    "data_inicio",
    "data_termino"
  ]
}
