{
  "name": "ProtocoloAdmINSS",
  "type": "object",
  "properties": {
    "administrativo_inss_id": {
      "type": "string"
    },
    "tipo_requerimento": {
      "type": "string",
      "enum": [
        "Aposentadoria",
        "Benef\u00edcio por incapacidade",
        "BPC/LOAS",
        "Pens\u00e3o por morte",
        "Sal\u00e1rio-maternidade",
        "Revis\u00e3o",
        "Recurso administrativo",
        "Certid\u00e3o de tempo de contribui\u00e7\u00e3o",
        "Emiss\u00e3o de guias",
        "Cumprimento de exig\u00eancia",
        "Outro"
      ]
    },
    "numero_protocolo": {
      "type": "string"
    },
    "data_protocolo": {
      "type": "string",
      "format": "date"
    },
    "canal_protocolo": {
      "type": "string",
      "enum": [
        "Meu INSS",
        "Presencial",
        "Telefone 135",
        "Outro"
      ]
    },
    "descricao_pedido": {
      "type": "string"
    },
    "documentos_apresentados": {
      "type": "string"
    },
    "status_requerimento": {
      "type": "string",
      "enum": [
        "Em elabora\u00e7\u00e3o",
        "Protocolado",
        "Em an\u00e1lise",
        "Exig\u00eancia emitida",
        "Deferido",
        "Indeferido",
        "Conclu\u00eddo"
      ],
      "default": "Em elabora\u00e7\u00e3o"
    },
    "data_decisao": {
      "type": "string",
      "format": "date"
    },
    "observacoes": {
      "type": "string"
    }
  },
  "required": [
    "administrativo_inss_id",
    "tipo_requerimento"
  ]
}
