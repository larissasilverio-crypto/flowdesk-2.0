{
  "name": "ManualEscritorio",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string",
      "description": "T\u00edtulo da se\u00e7\u00e3o do manual"
    },
    "conteudo": {
      "type": "string",
      "description": "Conte\u00fado do manual (comportamento, regras, etc)"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "Comportamento",
        "Processos",
        "Normas",
        "Diretrizes",
        "Outro"
      ],
      "default": "Comportamento"
    },
    "ordem": {
      "type": "number",
      "description": "Ordem de exibi\u00e7\u00e3o",
      "default": 0
    }
  },
  "required": [
    "titulo",
    "conteudo"
  ]
}
